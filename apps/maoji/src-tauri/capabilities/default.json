{
  "identifier": "default",
  "description": "Default capabilities for the maoji application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "dialog:default",
    "fs:allow-download-write",
    "fs:allow-download-read",
    "nfc:default",
    "nfc:allow-enable-nfc",
    "nfc:allow-disable-nfc",
    "nfc:allow-write-image",
    "core:app:allow-register-listener"
  ]
}
