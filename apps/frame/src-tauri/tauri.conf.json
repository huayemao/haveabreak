{
  "productName": "digital-frame",
  "version": "0.1.1",
  "identifier": "online.white-noise.frame",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Digital Frame",
        "width": 800,
        "height": 600,
        "url": "en/frame"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: 'unsafe-inline' https: data:; img-src 'self' https: data: blob:; media-src 'self' https: data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      }
    }
  },
  "build": {
    "frontendDist": "../../web/out"
  }
}
