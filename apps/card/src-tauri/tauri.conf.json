{
  "productName": "QuoteLite",
  "version": "0.1.0",
  "identifier": "online.white-noise.quotelite",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuoteLite",
        "width": 900,
        "height": 680,
        "url": "en/card"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: 'unsafe-inline' https: data:; img-src 'self' https: data:; media-src 'self' https: data:;"
    }
  },
  "bundle": {
    "iOS": {
      "developmentTeam": "12345ABCDE"
    },
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      }
    }
  },
  "build": {
    "frontendDist": "../../web/out"
  }
}
