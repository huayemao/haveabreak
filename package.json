{
  "name": "haveabreak-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @haveabreak/web dev",
    "build": "pnpm --filter @haveabreak/web build",
    "start": "pnpm --filter @haveabreak/web start",
    "lint": "pnpm --filter @haveabreak/web lint",
    "clean": "pnpm --filter @haveabreak/web clean",
    "tauri": "node tauri-router.js",
    "tauri:card": "export TAURI_APP=card && cd apps/card && npx tauri",
    "tauri:frame": "export TAURI_APP=frame && cd apps/frame && npx tauri",
    "tauri:timer": "export TAURI_APP=timer && cd apps/timer && npx tauri"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "typescript": "5.9.3"
  }
}